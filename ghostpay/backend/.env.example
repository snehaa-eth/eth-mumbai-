# ─────────────────────────────────────────────────────────
# BitGo Configuration
# ─────────────────────────────────────────────────────────
# Get your access token at: https://app.bitgo-test.com
#   1. Sign up at https://app.bitgo-test.com/signup (testnet)
#   2. Go to Settings → Developer → Access Tokens
#   3. Create a new token with "Spending" permission
#   4. Copy the token (you won't see it again)
BITGO_ACCESS_TOKEN=your_bitgo_testnet_access_token
BITGO_ENVIRONMENT=test
BITGO_ENTERPRISE_ID=your_enterprise_id
# BITGO_WALLET_ID is obtained after calling POST /wallet/create
BITGO_WALLET_ID=your_treasury_wallet_id
BITGO_WALLET_PASSPHRASE=your_wallet_passphrase
# BitGo coin: tusdc = Testnet USDC (ERC20 on Ethereum)
BITGO_COIN=tusdc

# ─────────────────────────────────────────────────────────
# Ethereum Sepolia
# ─────────────────────────────────────────────────────────
ETH_RPC_URL=https://sepolia.infura.io/v3/your_infura_project_id
# Block explorer for tx links
EXPLORER_URL=https://sepolia.etherscan.io

# ─────────────────────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram:
#   1. Open Telegram and search for @BotFather
#   2. Send /newbot
#   3. Choose a name (e.g. "GhostPay Bot")
#   4. Choose a username (e.g. "ghostpay_bot")
#   5. BotFather will give you a token like: 7123456789:AAF1234...
#   6. Paste that token below
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ─────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────
PORT=3001
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok.io

# ─────────────────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/ghostpay
# Atlas:   mongodb+srv://user:pass@cluster.mongodb.net/ghostpay
MONGODB_URI=mongodb://localhost:27017/ghostpay
